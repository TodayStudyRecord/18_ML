   "source": [
    "from sklearn.datasets import load_iris\n",
    "from sklearn.cluster import KMeans\n",
    "\n",
    "X = load_iris().data                 # 붓꽃 특성 4개 (정답인 품종은 안 씀)\n",
    "km = KMeans(n_clusters=3, random_state=0, n_init=10)\n",
    "labels = km.fit_predict(X)           # 각 꽃이 몇 번 무리인지 (0,1,2)\n",
    "print(labels[:10])"
   ]
  }
 ],
